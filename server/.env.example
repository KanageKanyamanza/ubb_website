# PayPal sandbox configuration example
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET_HERE

# Secret used to sign admin session tokens
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Admin backoffice credentials (espace /admin)
# Génère le hash avec : node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log('SALT='+s);console.log('HASH='+c.scryptSync('TON_MOT_DE_PASSE',s,64).toString('hex'))"
ADMIN_USERNAME=YOUR_ADMIN_USERNAME_HERE
ADMIN_PASSWORD_HASH=YOUR_ADMIN_PASSWORD_HASH_HERE
ADMIN_PASSWORD_SALT=YOUR_ADMIN_PASSWORD_SALT_HERE
